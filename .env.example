APP_ENV=local
LOG_LEVEL=INFO
ORCHESTRATION_MODE=http
DEMO_MODE=true
ENABLE_2FA=true
FRONTEND_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:5000,http://localhost:5050

JWT_SECRET_KEY=replace_me_with_a_long_random_secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
DATA_ENCRYPTION_ENABLED=false
DATA_ENCRYPTION_KEY=
DATA_ENCRYPTION_KEY_ID=local-dev-key-v1
DECRYPTION_LEASE_TTL_MINUTES=120

POSTGRES_DB=orientation
POSTGRES_USER=orientation
POSTGRES_PASSWORD=orientation
DATABASE_URL=postgresql+psycopg://orientation:orientation@postgres:5432/orientation
REDIS_URL=redis://redis:6379/0

MATURITY_MODEL_PROVIDER=rules
BLOCKER_MODEL_PROVIDER=rules
SCORING_MODEL_PROVIDER=weighted_rules
LLM_PROVIDER=mock
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
GEMINI_API_KEY=

API_GATEWAY_URL=http://api_gateway:5050
INTAKE_SERVICE_URL=http://intake_service:5051
PROFILE_SERVICE_URL=http://profile_service:5052
MATURITY_SERVICE_URL=http://maturity_service:5053
SCORING_SERVICE_URL=http://scoring_service:5054
BLOCKER_SERVICE_URL=http://blocker_service:5055
CONFIDENCE_SERVICE_URL=http://confidence_service:5056
RESOURCE_SERVICE_URL=http://resource_service:5057
ELIGIBILITY_SERVICE_URL=http://eligibility_service:5058
ROADMAP_SERVICE_URL=http://roadmap_service:5059
PROGRESS_SERVICE_URL=http://progress_service:5060
